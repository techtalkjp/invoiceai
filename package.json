{
  "name": "invoiceai",
  "version": "1.0.0",
  "description": "AI-powered invoice management for freelancers and small teams",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "cli:freee": "tsx src/list-invoices.ts",
    "cli:auth": "tsx src/auth.ts",
    "cli:google": "tsx src/google-auth.ts",
    "cli:invoice": "tsx src/create-invoice.ts",
    "cli:activity": "tsx src/sync-activities.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "cli:typecheck": "tsc -p tsconfig.json",
    "lint": "biome lint .",
    "format": "prettier . --check --experimental-cli",
    "format:fix": "prettier . --write --experimental-cli",
    "typecheck": "react-router typegen && tsc",
    "validate": "run-p format lint && run-p typecheck",
    "db:push": "atlas schema apply --env local --auto-approve",
    "db:push:production": "dotenv -e .env.production -- atlas schema apply --env production --auto-approve",
    "db:types": "kysely-codegen --dialect libsql --camel-case --url file:db/local.db --out-file app/lib/db/types.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@ai-sdk/google": "3.0.58",
    "@base-ui/react": "1.3.0",
    "@conform-to/react": "1.18.0",
    "@conform-to/zod": "1.18.0",
    "@fontsource-variable/noto-sans": "5.2.10",
    "@holiday-jp/holiday_jp": "2.5.1",
    "@libsql/client": "0.17.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-pdf/renderer": "4.3.2",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@tabler/icons-react": "3.41.1",
    "@vercel/react-router": "1.2.6",
    "ai": "6.0.146",
    "better-auth": "1.5.6",
    "cac": "7.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.20",
    "dotenv": "17.4.0",
    "isbot": "5.1.37",
    "kysely": "0.28.15",
    "kysely-libsql": "0.7.1",
    "lucide-react": "1.7.0",
    "nanoid": "5.1.7",
    "pdf-lib": "1.17.1",
    "radix-ui": "latest",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.14.0",
    "shadcn": "4.1.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "ts-pattern": "5.9.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vaul": "1.1.2",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write --experimental-cli"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "11.0.0",
    "husky": "9.1.7",
    "kysely-codegen": "0.20.0",
    "lint-staged": "16.4.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "react-router-auto-routes": "0.8.3",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "vite": "8.0.3",
    "vite-plugin-devtools-json": "1.0.0",
    "vitest": "4.1.2"
  }
}
