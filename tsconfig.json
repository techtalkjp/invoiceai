{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    }
  },
  "include": [
    "app/**/*",
    "public/**/*",
    "react-router.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    ".react-router/types/**/*"
  ]
}
