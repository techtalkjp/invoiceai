
# Turso Database (本番環境用)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# better-auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your_api_key

# freee API
FREEE_API_CLIENT_ID=your_freee_api_client_id
FREEE_API_CLIENT_SECRET=your_freee_api_client_secret

# Activity Sources (GitHub連携)
ENCRYPTION_KEY=  # base64エンコードされた32バイトのキー (openssl rand -base64 32)
CRON_SECRET=     # Cronエンドポイント用のAPIキー

# GitHub App (Settings 外部連携)
GITHUB_APP_ID=                    # GitHub App の App ID
GITHUB_APP_SLUG=                  # GitHub App の URL スラッグ (例: invoiceai)
GITHUB_APP_PRIVATE_KEY=           # GitHub App の秘密鍵 (PEM形式、\n でエスケープ)
GITHUB_APP_WEBHOOK_SECRET=        # GitHub App の Webhook シークレット

# ngrok (開発時のみ。pnpm tunnel で使用)
NGROK_DOMAIN=              # ngrok の固定ドメイン (例: xxx.ngrok-free.app)

# CLI (開発時のみ。本番ユーザーは設定不要)
INVOICEAI_SERVER_URL=http://localhost:5173

# GitHub OAuth (Playground デモ用)
GITHUB_CLIENT_ID=      # GitHub OAuth App の Client ID
GITHUB_CLIENT_SECRET=  # GitHub OAuth App の Client Secret
